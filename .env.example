# ============================================================
# Issue Pipeline - 환경변수 설정 예시
# 이 파일을 복사하여 .env 파일을 생성하세요:
#   cp .env.example .env
# ============================================================

# ---- LLM 백엔드 설정 ----
LLM_BACKEND=claude               # claude(인터넷 연결) | ollama(폐쇄망)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b          # 추천: qwen2.5:7b, exaone3.5:7.8b, llama3.1:8b

# ---- LLM 설정 (claude 백엔드 사용 시) ----
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- 임베딩 설정 ----
OPENAI_API_KEY=sk-your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-3-small

# ---- ChromaDB 설정 ----
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=issue_documents

# ---- 청킹 설정 ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ---- 검색 설정 ----
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.3

# ---- API 서버 설정 ----
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_LOG_LEVEL=info

# ---- 문서 수집 경로 ----
RAW_DOCUMENTS_DIR=./data/raw
PROCESSED_DOCUMENTS_DIR=./data/processed

# ---- 로깅 설정 ----
LOG_LEVEL=INFO
LOG_FORMAT=json
