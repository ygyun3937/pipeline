# ============================================================
# Issue Pipeline - 환경변수 설정 예시
# 이 파일을 복사하여 .env 파일을 생성하세요:
#   cp .env.example .env
# ============================================================

# ---- LLM 백엔드 설정 ----
# claude    : Claude Agent SDK (Claude Code 구독 필요, 별도 API 키 불필요)
#             ※ Claude Code 터미널에서 직접 실행해야 함 (중첩 세션 불가)
# anthropic : Anthropic API 직접 호출 (ANTHROPIC_API_KEY 필요, 서버/스크립트 실행 모두 가능)
# ollama    : 로컬 Ollama 서버 (폐쇄망 환경, 외부 연결 불필요)
LLM_BACKEND=claude

# ---- Anthropic API 설정 (LLM_BACKEND=anthropic 시 사용) ----
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Ollama 설정 (LLM_BACKEND=ollama 시 사용) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b          # 추천: qwen2.5:7b, exaone3.5:7.8b, llama3.1:8b

# ---- ChromaDB 설정 ----
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=issue_documents

# ---- 청킹 설정 ----
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ---- 검색 설정 ----
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.4

# ---- API 서버 설정 ----
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_LOG_LEVEL=info

# ---- 문서 수집 경로 ----
RAW_DOCUMENTS_DIR=./data/raw
PROCESSED_DOCUMENTS_DIR=./data/processed

# ---- 로깅 설정 ----
LOG_LEVEL=INFO
LOG_FORMAT=text
